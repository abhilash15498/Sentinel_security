# ============================================================
# SENTINEL - Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# --- Email Alerts ---
EMAIL_SENDER=enter_sender_email
EMAIL_PASSWORD=generate_app_password
EMAIL_RECEIVER=enter_receiver_email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# --- Telegram Alerts (optional) ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- System Config ---
SENTINEL_LOG_LEVEL=INFO
FACE_CONFIDENCE_THRESHOLD=0.75
ALERT_COOLDOWN_SECONDS=30
SCREENSHOT_ON_INTRUSION=true
TTS_ENABLED=true
SOUND_ALARM_ENABLED=true

# --- USB Monitoring ---
USB_MONITOR_ENABLED=true

# --- Face Recognition Mode ---
# Options: opencv_only | deepface
FACE_RECOGNITION_MODE=opencv_only
